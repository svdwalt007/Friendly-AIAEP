# ==============================================================================
# Docker Ignore Configuration
# ==============================================================================
# Excludes unnecessary files from Docker build context to:
# - Reduce build context size
# - Speed up builds
# - Prevent sensitive data from entering images
# - Improve layer caching
# ==============================================================================

# ==============================================================================
# Version Control
# ==============================================================================
.git
.gitignore
.gitattributes
.github

# ==============================================================================
# Documentation and Markdown
# ==============================================================================
*.md
!README.md
docs/
*.markdown
*.docx
*.svg

# ==============================================================================
# CI/CD and Deployment
# ==============================================================================
.circleci
.travis.yml
.gitlab-ci.yml
azure-pipelines.yml
.jenkins
.drone.yml
netlify.toml
vercel.json

# ==============================================================================
# Development Environment
# ==============================================================================
.vscode
.idea
.vs
.vscode-test
.angular
.verdaccio
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ==============================================================================
# Node.js and Package Managers
# ==============================================================================
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store
.yarn
.npm
.npmrc.local

# ==============================================================================
# Build Outputs (Context-specific, may need adjustment)
# ==============================================================================
dist
build
out
.next
.nuxt
.cache
.parcel-cache
.turbo

# ==============================================================================
# Test Coverage and Reports
# ==============================================================================
coverage
.nyc_output
*.lcov
test-results/
playwright-report/
junit.xml
*.junit.xml

# ==============================================================================
# Environment and Configuration
# ==============================================================================
.env
.env.*
!.env.example
!.env.template
*.local
.envrc

# ==============================================================================
# Logs
# ==============================================================================
*.log
logs
*.log.*
log/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ==============================================================================
# Temporary Files
# ==============================================================================
tmp
temp
*.tmp
*.temp
.temp
.tmp

# ==============================================================================
# OS Files
# ==============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ==============================================================================
# Docker
# ==============================================================================
.dockerignore
Dockerfile
Dockerfile.*
docker-compose*.yml
.docker

# ==============================================================================
# Kubernetes and Deployment
# ==============================================================================
helm/
k8s/
kubernetes/
deploy/
!docker/

# ==============================================================================
# Testing
# ==============================================================================
.jest
.mocha
.karma
test/
tests/
__tests__/
**/*.test.js
**/*.test.ts
**/*.spec.js
**/*.spec.ts
e2e/
cypress/
playwright/

# ==============================================================================
# TypeScript
# ==============================================================================
*.tsbuildinfo
.tscache

# ==============================================================================
# ESLint and Prettier
# ==============================================================================
.eslintcache
.prettierignore
.prettierrc*
.eslintrc*
.eslintignore

# ==============================================================================
# Nx Specific
# ==============================================================================
.nx/cache
.nx/workspace-data
project-graph.html
build-output.txt

# ==============================================================================
# Database
# ==============================================================================
*.sqlite
*.sqlite3
*.db
*.sql
prisma/migrations
prisma/dev.db*

# ==============================================================================
# Secrets and Credentials
# ==============================================================================
*.pem
*.key
*.cert
*.crt
*.csr
secrets/
credentials/
*.p12
*.pfx

# ==============================================================================
# Editor Backups
# ==============================================================================
*~
*.swp
*.swo
*.swn
.#*

# ==============================================================================
# Miscellaneous
# ==============================================================================
.husky
.commitlintrc*
.lintstagedrc*
.editorconfig
.nvmrc
.node-version
.tool-versions

# ==============================================================================
# Python (if any Python tools are used)
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
ENV/

# ==============================================================================
# Project Specific
# ==============================================================================
GETTING-STARTED.md
IMPLEMENTATION-COMPLETE.md
PREVIEW-SYSTEM-STATUS.md
CLAUDE.md
ARCHITECTURE.md

# ==============================================================================
# Keep These Files (Negation Patterns)
# ==============================================================================
!pnpm-workspace.yaml
!pnpm-lock.yaml
