# ============================================================================
# Friendly AI AEP Tool - Pre-Production Environment
# ============================================================================
# This file contains pre-production configuration
# Used for final testing before production release
# ============================================================================

# Deployment Mode
DEPLOYMENT_MODE=preprod
NODE_ENV=production

# ============================================================================
# Friendly API Endpoints
# ============================================================================
# Pre-prod endpoints point to staging instances
FRIENDLY_API_URL_PRIMARY=https://api-preprod.friendly.example.com
FRIENDLY_API_KEY_PRIMARY=CHANGE_ME_preprod_primary_api_key

FRIENDLY_API_URL_SECONDARY=https://api-preprod.friendly.example.com
FRIENDLY_API_KEY_SECONDARY=CHANGE_ME_preprod_secondary_api_key

FRIENDLY_API_URL_TERTIARY=https://api-preprod.friendly.example.com
FRIENDLY_API_KEY_TERTIARY=CHANGE_ME_preprod_tertiary_api_key

# ============================================================================
# Anthropic API Configuration
# ============================================================================
ANTHROPIC_API_KEY=CHANGE_ME_preprod_anthropic_key
ANTHROPIC_API_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=4096

# ============================================================================
# Application Ports
# ============================================================================
AEP_API_GATEWAY_PORT=3001
AEP_BUILDER_PORT=80
AEP_PREVIEW_HOST_PORT=3002

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL - Pre-production database
DATABASE_URL=postgresql://CHANGE_ME_USER:CHANGE_ME_PASSWORD@preprod-db.example.com:5432/friendly_aep_preprod
POSTGRES_HOST=preprod-db.example.com
POSTGRES_PORT=5432
POSTGRES_USER=CHANGE_ME_USER
POSTGRES_PASSWORD=CHANGE_ME_PASSWORD
POSTGRES_DB=friendly_aep_preprod

# ============================================================================
# Time-Series Database (InfluxDB)
# ============================================================================
INFLUXDB_URL=https://influxdb-preprod.example.com
INFLUXDB_TOKEN=CHANGE_ME_preprod_influxdb_token
INFLUXDB_ORG=friendly
INFLUXDB_BUCKET=iot_data
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=CHANGE_ME_preprod_influx_password

# ============================================================================
# Grafana Configuration
# ============================================================================
GRAFANA_URL=https://grafana-preprod.friendly-aep.example.com
GRAFANA_ROOT_URL=https://grafana-preprod.friendly-aep.example.com
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_preprod_grafana_password
GRAFANA_API_KEY=CHANGE_ME_preprod_grafana_api_key

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_HOST=preprod-redis.example.com
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_preprod_redis_password
REDIS_DB=0
REDIS_URL=redis://:CHANGE_ME_preprod_redis_password@preprod-redis.example.com:6379

# ============================================================================
# Object Storage (S3 or MinIO)
# ============================================================================
# Using AWS S3 for pre-prod
AWS_S3_BUCKET=friendly-aep-preprod-storage
AWS_ACCESS_KEY_ID=CHANGE_ME_preprod_aws_key
AWS_SECRET_ACCESS_KEY=CHANGE_ME_preprod_aws_secret
AWS_REGION=us-east-1

# MinIO alternative
MINIO_ENDPOINT=preprod-minio.example.com
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME_preprod_minio_access
MINIO_SECRET_KEY=CHANGE_ME_preprod_minio_secret
MINIO_USE_SSL=true
MINIO_BUCKET=friendly-aep-storage-preprod

# ============================================================================
# Authentication & Security
# ============================================================================
# Use production-grade secrets (must be changed)
JWT_SECRET=CHANGE_ME_preprod_jwt_secret_minimum_32_characters_long_strong_secret
JWT_EXPIRATION=8h
REFRESH_TOKEN_SECRET=CHANGE_ME_preprod_refresh_secret_minimum_32_characters_long_strong
REFRESH_TOKEN_EXPIRATION=3d

SESSION_SECRET=CHANGE_ME_preprod_session_secret_minimum_32_characters_long_strong
SESSION_MAX_AGE=28800000

# CORS - Restricted to pre-prod domain
CORS_ORIGIN=https://preprod.friendly-aep.example.com
CORS_CREDENTIALS=true

# ============================================================================
# IoT Configuration
# ============================================================================
IOT_MOCK_API_ENABLED=false
IOT_MOCK_API_PORT=3003

TELEGRAF_ENABLED=true
TELEGRAF_METRICS_PORT=8125
TELEGRAF_HTTP_PORT=8094

# ============================================================================
# Builder Configuration
# ============================================================================
GIT_PROVIDER=github
GIT_TOKEN=CHANGE_ME_preprod_github_token
GIT_DEFAULT_ORG=friendly-preprod

TEMPLATE_MARKETPLACE_ENABLED=true
TEMPLATE_MARKETPLACE_URL=https://templates-preprod.friendly.example.com

# ============================================================================
# Licensing & Billing
# ============================================================================
LICENSE_SERVICE_ENABLED=true
LICENSE_API_URL=https://license-preprod.friendly.example.com
LICENSE_API_KEY=CHANGE_ME_preprod_license_key

BILLING_SERVICE_ENABLED=true
BILLING_PROVIDER=stripe
STRIPE_API_KEY=CHANGE_ME_preprod_stripe_key
STRIPE_WEBHOOK_SECRET=CHANGE_ME_preprod_stripe_webhook_secret

# ============================================================================
# Audit & Logging
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
AUDIT_ENABLED=true
AUDIT_LOG_PATH=/var/log/friendly-aep/audit.log

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_IOT_ENABLED=true
FEATURE_BUILDER_ENABLED=true
FEATURE_GRAFANA_INTEGRATION=true
FEATURE_AI_AGENT_RUNTIME=true

# ============================================================================
# Production Settings
# ============================================================================
DEV_MODE=false
DEV_DEBUG_ENABLED=false
DEV_MOCK_SERVICES=false
WATCH_MODE=false

# ============================================================================
# Docker Compose
# ============================================================================
COMPOSE_PROJECT_NAME=friendly-aep-preprod
COMPOSE_FILE=docker/docker-compose.preprod.yml

# ============================================================================
# Monitoring & Alerting
# ============================================================================
SENTRY_DSN=CHANGE_ME_preprod_sentry_dsn
SENTRY_ENVIRONMENT=preprod
SENTRY_TRACES_SAMPLE_RATE=0.5

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
