# PostgreSQL Checkpointer Configuration
# Copy this file to .env and update with your values

# Database Host
POSTGRES_HOST=localhost

# Database Port (default: 5432)
POSTGRES_PORT=5432

# Database Name
POSTGRES_DB=aep_dev

# Database User
POSTGRES_USER=postgres

# Database Password
POSTGRES_PASSWORD=postgres

# Maximum number of connections in pool (default: 10)
POSTGRES_MAX_CONNECTIONS=10

# Enable SSL connection (default: false)
# Set to 'true' for production
POSTGRES_SSL=false

# Optional: SSL Certificate Authority (for production)
# POSTGRES_SSL_CA=/path/to/ca-certificate.crt

# Optional: Connection timeouts (in milliseconds)
# POSTGRES_IDLE_TIMEOUT=30000
# POSTGRES_CONNECTION_TIMEOUT=5000

# Production Settings (uncomment for production)
# POSTGRES_HOST=your-prod-db-host.example.com
# POSTGRES_DB=aep_production
# POSTGRES_USER=aep_app_user
# POSTGRES_PASSWORD=<strong-secure-password>
# POSTGRES_MAX_CONNECTIONS=50
# POSTGRES_SSL=true
# POSTGRES_SSL_CA=/etc/ssl/certs/postgresql-ca.crt
