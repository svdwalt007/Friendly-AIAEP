{
  "name": "shared-secrets",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/secrets/src",
  "projectType": "library",
  "tags": ["type:shared", "scope:backend"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/secrets",
        "main": "libs/shared/secrets/src/index.ts",
        "tsConfig": "libs/shared/secrets/tsconfig.lib.json",
        "assets": ["libs/shared/secrets/*.md"]
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../../coverage/libs/shared/secrets"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
