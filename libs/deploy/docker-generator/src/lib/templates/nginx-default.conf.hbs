# Friendly AI AEP Tool - Nginx Reverse Proxy Configuration
# Project: {{project.projectName}}
# Version: {{project.version}}
# Deployment Mode: {{environment.deploymentMode}}

# =============================================================================
# Upstream Definitions
# =============================================================================

# Frontend (Angular application)
upstream frontend {
    server frontend:80;
    keepalive 32;
}

# Grafana (Monitoring dashboards)
upstream grafana {
    server grafana:3000;
    keepalive 16;
}

# IoT API Proxy (Friendly DM API gateway)
upstream iot-api-proxy {
    server iot-api-proxy:8080;
    keepalive 64;
}

# License Agent
upstream license-agent {
    server license-agent:8080;
    keepalive 8;
}

{{#if isEnterprise}}
# Ollama (Enterprise only)
upstream ollama {
    server ollama:11434;
    keepalive 8;
}

{{/if}}
# =============================================================================
# HTTP Server Configuration
# =============================================================================

server {
    listen 80;
{{#if isDedicated}}
    server_name localhost {{project.projectId}}.{{environment.baseDomain}};
{{else}}
    server_name {{project.projectId}}.{{environment.baseDomain}};
{{/if}}

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Client body size limit (for file uploads)
    client_max_body_size 50M;

    # Timeouts
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;

    # Buffer settings
    proxy_buffering on;
    proxy_buffer_size 4k;
    proxy_buffers 8 4k;
    proxy_busy_buffers_size 8k;

    # =================================================================
    # Health Check Endpoint
    # =================================================================
    location /health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }

    # =================================================================
    # API Routes -> iot-api-proxy:8080
    # =================================================================
    location /api/ {
        # Remove /api prefix when proxying
        rewrite ^/api/(.*)$ /$1 break;

        proxy_pass http://iot-api-proxy;

        # WebSocket support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Proxy headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        # CORS headers (for SaaS mode)
{{#if isSaas}}
        add_header Access-Control-Allow-Origin "https://{{project.projectId}}.{{environment.baseDomain}}" always;
        add_header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, PATCH, OPTIONS" always;
        add_header Access-Control-Allow-Headers "Authorization, Content-Type, X-Requested-With, X-Tenant-ID" always;
        add_header Access-Control-Allow-Credentials "true" always;
{{/if}}

        # Handle preflight requests
        if ($request_method = 'OPTIONS') {
            add_header Access-Control-Max-Age 1728000;
            add_header Content-Type 'text/plain; charset=utf-8';
            add_header Content-Length 0;
            return 204;
        }
    }

    # =================================================================
    # Grafana Routes -> grafana:3000
    # =================================================================
    location /grafana/ {
        # Remove /grafana prefix when proxying
        rewrite ^/grafana/(.*)$ /$1 break;

        proxy_pass http://grafana;

        # WebSocket support for live dashboards
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Proxy headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        # Grafana-specific headers
        proxy_set_header X-WEBAUTH-USER $remote_user;
    }

    # Grafana API (direct access without prefix removal)
    location /grafana/api/ {
        proxy_pass http://grafana;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # =================================================================
    # License Agent Routes (Internal only)
    # =================================================================
    location /license/ {
        # Restrict access to internal network only
        allow 172.28.0.0/16;
        deny all;

        rewrite ^/license/(.*)$ /$1 break;
        proxy_pass http://license-agent;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

{{#if isEnterprise}}
    # =================================================================
    # Ollama Routes (Enterprise only, Internal only)
    # =================================================================
    location /ollama/ {
        # Restrict access to internal network only
        allow 172.28.0.0/16;
        deny all;

        rewrite ^/ollama/(.*)$ /$1 break;
        proxy_pass http://ollama;

        # Increase timeouts for LLM operations
        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Disable buffering for streaming responses
        proxy_buffering off;
    }

{{/if}}
    # =================================================================
    # WebSocket Routes (Agent Streaming)
    # =================================================================
    location /ws/ {
        proxy_pass http://iot-api-proxy;

        # WebSocket upgrade
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Proxy headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket-specific settings
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_buffering off;
    }

    # =================================================================
    # Static Assets (Frontend)
    # =================================================================
    location /assets/ {
        proxy_pass http://frontend;

        # Cache static assets
        expires 1y;
        add_header Cache-Control "public, immutable";

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # =================================================================
    # Frontend Application (Default route)
    # =================================================================
    location / {
        proxy_pass http://frontend;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        # Support for Angular routing (HTML5 mode)
        proxy_intercept_errors on;
        error_page 404 = @frontend_fallback;
    }

    # Fallback for Angular routes
    location @frontend_fallback {
        proxy_pass http://frontend;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

{{#if isDedicated}}
# =============================================================================
# HTTPS Server Configuration (Dedicated deployments only)
# =============================================================================

server {
    listen 443 ssl http2;
    server_name {{project.projectId}}.{{environment.baseDomain}};

    # SSL certificate paths
    ssl_certificate /etc/nginx/ssl/cert.pem;
    ssl_certificate_key /etc/nginx/ssl/key.pem;

    # SSL configuration
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    # Security headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # Include all location blocks from HTTP server
    include /etc/nginx/conf.d/locations.conf;
}

{{/if}}
