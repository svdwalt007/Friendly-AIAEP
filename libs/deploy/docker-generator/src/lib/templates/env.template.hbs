# =============================================================================
# Friendly AI AEP Tool - Environment Configuration
# =============================================================================
# Project: {{project.projectName}}
# Version: {{project.version}}
# Deployment Mode: {{environment.deploymentMode}}
# Tier: {{project.tier}}
# Generated: {{metadata.generatedAt}}
#
# IMPORTANT: Copy this file to .env and fill in the required values
# =============================================================================

# =============================================================================
# PROJECT CONFIGURATION
# =============================================================================

# Deployment mode: 'saas' (shared multi-tenant) or 'dedicated' (self-contained)
DEPLOYMENT_MODE={{environment.deploymentMode}}

# Unique project identifier
PROJECT_ID={{project.projectId}}

# Project version
PROJECT_VERSION={{project.version}}

# Base domain for SaaS deployments
BASE_DOMAIN={{environment.baseDomain}}

# =============================================================================
# FRIENDLY ONE-IOT DM API CREDENTIALS
# =============================================================================
# Configure credentials for all three Friendly One-IoT Device Management APIs
# Each API supports both Basic Auth (username/password) and API Key authentication

# -----------------------------------------------------------------------------
# Northbound REST API
# -----------------------------------------------------------------------------
# Handles: Device management, provisioning, firmware updates, LwM2M operations
NORTHBOUND_API_URL={{environment.northboundApi.url}}
NORTHBOUND_AUTH_METHOD={{environment.northboundApi.authMethod}}
# For Basic Auth (authMethod=basic):
NORTHBOUND_USERNAME=
NORTHBOUND_PASSWORD=
# For API Key Auth (authMethod=apikey):
NORTHBOUND_API_KEY=

# -----------------------------------------------------------------------------
# Events/Webhook REST API
# -----------------------------------------------------------------------------
# Handles: Real-time event subscriptions, device state changes, webhooks
EVENTS_API_URL={{environment.eventsApi.url}}
EVENTS_AUTH_METHOD={{environment.eventsApi.authMethod}}
# For Basic Auth (authMethod=basic):
EVENTS_USERNAME=
EVENTS_PASSWORD=
# For API Key Auth (authMethod=apikey):
EVENTS_API_KEY=

# -----------------------------------------------------------------------------
# QoE/Monitoring REST API
# -----------------------------------------------------------------------------
# Handles: Time-series KPIs, monitoring data, quality of experience metrics
QOE_API_URL={{environment.qoeApi.url}}
QOE_AUTH_METHOD={{environment.qoeApi.authMethod}}
# For Basic Auth (authMethod=basic):
QOE_USERNAME=
QOE_PASSWORD=
# For API Key Auth (authMethod=apikey):
QOE_API_KEY=

# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================
# Configure the Large Language Model provider for AI agent functionality
# Supported providers: 'anthropic' (all tiers), 'ollama' (Enterprise only)

# Primary LLM provider
LLM_PROVIDER={{environment.llmProvider.provider}}

# Default model to use
LLM_DEFAULT_MODEL={{environment.llmProvider.defaultModel}}

{{#if (eq environment.llmProvider.provider 'anthropic')}}
# Anthropic API Key (required for Anthropic provider)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

{{/if}}
{{#if isEnterprise}}
{{#if (eq environment.llmProvider.provider 'ollama')}}
# Ollama Configuration (Enterprise tier only)
# URL to Ollama server (self-hosted or dedicated instance)
OLLAMA_URL={{environment.llmProvider.ollamaUrl}}

# Ollama model to use (e.g., llama2, mistral, codellama)
OLLAMA_MODEL={{environment.llmProvider.ollamaModel}}

{{/if}}
{{/if}}
{{#if environment.llmProvider.fallback}}
# Fallback LLM Configuration (optional)
# Used when primary provider is unavailable
LLM_FALLBACK_PROVIDER={{environment.llmProvider.fallback.provider}}
LLM_FALLBACK_MODEL={{environment.llmProvider.fallback.model}}

{{/if}}
# =============================================================================
# LICENSE CONFIGURATION
# =============================================================================
# License validation and heartbeat configuration

# Your Friendly AI AEP Tool license key
# Contact sales@friendly-tech.com for a license
LICENSE_KEY=

# Tenant ID (provided with your license)
TENANT_ID={{license.tenantId}}

# Heartbeat interval for license validation (e.g., 1h, 30m, 24h)
HEARTBEAT_INTERVAL={{#if license.heartbeatInterval}}{{license.heartbeatInterval}}{{else}}1h{{/if}}

# Grace period settings (allows operation during temporary connectivity issues)
GRACE_PERIOD_ENABLED={{#if license.gracePeriod.enabled}}true{{else}}false{{/if}}
GRACE_PERIOD_DURATION={{#if license.gracePeriod.duration}}{{license.gracePeriod.duration}}{{else}}0{{/if}}

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (Relational Database)
# -----------------------------------------------------------------------------
# Stores: Project metadata, user data, agent state, configuration

POSTGRES_HOST={{environment.database.postgres.host}}
POSTGRES_PORT={{environment.database.postgres.port}}
POSTGRES_DB={{environment.database.postgres.database}}
POSTGRES_USER={{environment.database.postgres.username}}
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# InfluxDB (Time-Series Database)
# -----------------------------------------------------------------------------
# Stores: IoT device metrics, time-series data, monitoring KPIs

INFLUXDB_URL={{environment.database.influxdb.url}}
INFLUXDB_ORG={{environment.database.influxdb.org}}
INFLUXDB_BUCKET={{environment.database.influxdb.bucket}}
INFLUXDB_TOKEN=
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=

{{#if hasThirdPartyIngestion}}
# External data bucket for third-party ingestion (Professional+ tier)
INFLUXDB_BUCKET_EXTERNAL=external_data

{{/if}}
# -----------------------------------------------------------------------------
# Redis (Cache & Rate Limiting)
# -----------------------------------------------------------------------------
# Stores: Session cache, rate limiting counters, temporary data

REDIS_HOST={{environment.redis.host}}
REDIS_PORT={{environment.redis.port}}
{{#if environment.redis.password}}
REDIS_PASSWORD=

{{/if}}
# =============================================================================
# GRAFANA CONFIGURATION
# =============================================================================
# Monitoring dashboards and visualization platform

# Grafana admin credentials
GRAFANA_ADMIN_USER={{environment.grafana.adminUsername}}
GRAFANA_ADMIN_PASSWORD=

# Grafana theme customization (optional)
GF_THEME_PATH=/usr/share/grafana/public/build/theme

{{#if hasThirdPartyIngestion}}
# =============================================================================
# THIRD-PARTY DATA INGESTION (Professional+ Tier)
# =============================================================================
# Configure external data sources for ingestion via Telegraf

# Enable MQTT ingestion
THIRD_PARTY_MQTT_ENABLED={{environment.thirdPartyIngestion.mqtt.enabled}}
{{#if environment.thirdPartyIngestion.mqtt.enabled}}
THIRD_PARTY_MQTT_BROKER={{environment.thirdPartyIngestion.mqtt.broker}}
THIRD_PARTY_MQTT_TOPIC={{environment.thirdPartyIngestion.mqtt.topic}}
THIRD_PARTY_MQTT_USERNAME={{environment.thirdPartyIngestion.mqtt.username}}
THIRD_PARTY_MQTT_PASSWORD=
{{/if}}

# Enable HTTP/REST ingestion
THIRD_PARTY_HTTP_ENABLED={{environment.thirdPartyIngestion.http.enabled}}
{{#if environment.thirdPartyIngestion.http.enabled}}
THIRD_PARTY_HTTP_ENDPOINT={{environment.thirdPartyIngestion.http.endpoint}}
THIRD_PARTY_HTTP_METHOD={{environment.thirdPartyIngestion.http.method}}
THIRD_PARTY_HTTP_INTERVAL={{environment.thirdPartyIngestion.http.interval}}
{{/if}}

{{/if}}
# =============================================================================
# ADVANCED CONFIGURATION (Optional)
# =============================================================================

{{#if isDedicated}}
# SSL/TLS Configuration (Dedicated deployments only)
SSL_ENABLED=false
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

{{/if}}
# Logging configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Feature flags
{{#if hasGit}}
FEATURE_GIT_ENABLED=true
{{/if}}
{{#if hasHelm}}
FEATURE_HELM_ENABLED=true
{{/if}}
{{#if hasCustomWidgets}}
FEATURE_CUSTOM_WIDGETS_ENABLED=true
{{/if}}
{{#if hasAirgap}}
FEATURE_AIRGAP_MODE=true
{{/if}}

# Rate limiting configuration (tier-based)
{{#if isEnterprise}}
RATE_LIMIT_CALLS_PER_MONTH=20000000
{{else}}{{#if isProfessional}}
RATE_LIMIT_CALLS_PER_MONTH=2000000
{{else}}
RATE_LIMIT_CALLS_PER_MONTH=100000
{{/if}}{{/if}}
RATE_LIMIT_BURST_SIZE=100

# Session configuration
SESSION_SECRET=
SESSION_TIMEOUT=3600

# CORS configuration
{{#if isSaas}}
CORS_ALLOWED_ORIGINS=https://*.${BASE_DOMAIN}
{{else}}
CORS_ALLOWED_ORIGINS=http://localhost:3000
{{/if}}

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
