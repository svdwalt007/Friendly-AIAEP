# {{projectName}} Environment Configuration
# Generated by Friendly AI AEP Docker Generator
# Deployment Mode: {{deploymentMode}}

NODE_ENV={{environment}}
DEPLOYMENT_MODE={{deploymentMode}}

# API Configuration
AEP_API_GATEWAY_PORT={{apiGatewayPort}}
AEP_BUILDER_PORT={{builderPort}}
AEP_PREVIEW_HOST_PORT={{previewHostPort}}

# Friendly API Endpoints
{{#each apiEndpoints}}
FRIENDLY_API_URL_{{@key}}={{this.url}}
FRIENDLY_API_KEY_{{@key}}=CHANGE_ME
{{/each}}

# Anthropic LLM
ANTHROPIC_API_KEY=CHANGE_ME
ANTHROPIC_MODEL={{anthropicModel}}
ANTHROPIC_MAX_TOKENS={{anthropicMaxTokens}}

# Database
DATABASE_URL=postgresql://{{dbUser}}:CHANGE_ME@postgres:5432/{{dbName}}
POSTGRES_USER={{dbUser}}
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB={{dbName}}

# InfluxDB
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=CHANGE_ME
INFLUXDB_ORG={{influxOrg}}
INFLUXDB_BUCKET={{influxBucket}}

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# JWT
JWT_SECRET=CHANGE_ME_minimum_32_characters
REFRESH_TOKEN_SECRET=CHANGE_ME_minimum_32_characters

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
