{
  "name": "friendly-aiaep",
  "version": "1.0.0",
  "description": "Friendly AI AEP Tool - Nx Monorepo",
  "scripts": {
    "build": "nx run-many --target=build --exclude=friendly-aiaep",
    "test": "nx run-many --target=test --exclude=friendly-aiaep",
    "lint": "nx run-many --target=lint --exclude=friendly-aiaep",
    "affected:build": "nx affected --target=build",
    "affected:test": "nx affected --target=test",
    "affected:lint": "nx affected --target=lint",
    "graph": "nx graph",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:components": "playwright test -c playwright-ct.config.ts",
    "test:components:ui": "playwright test -c playwright-ct.config.ts --ui",
    "test:visual": "percy exec -- playwright test tests/visual/",
    "test:visual:local": "playwright test tests/visual/",
    "test:a11y": "playwright test --grep @accessibility",
    "test:report": "playwright show-report",
    "test:install": "playwright install",
    "test:install:deps": "playwright install --with-deps"
  },
  "keywords": [
    "nx",
    "monorepo",
    "friendly",
    "aep"
  ],
  "author": "Friendly Technology",
  "license": "UNLICENSED",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
