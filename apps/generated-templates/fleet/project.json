{
  "name": "fleet",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "fl",
  "sourceRoot": "apps/generated-templates/fleet/src",
  "tags": ["scope:generated-template"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/generated-templates/fleet",
        "browser": "apps/generated-templates/fleet/src/main.ts",
        "index": "apps/generated-templates/fleet/src/index.html",
        "tsConfig": "apps/generated-templates/fleet/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/generated-templates/fleet/public"
          }
        ],
        "styles": ["apps/generated-templates/fleet/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "budgets": [
            { "type": "initial", "maximumWarning": "200kb", "maximumError": "250kb" },
            { "type": "anyComponentStyle", "maximumWarning": "8kb", "maximumError": "16kb" }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true,
          "outputHashing": "none"
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": { "port": 45011, "host": "localhost" },
      "configurations": {
        "production": { "buildTarget": "fleet:build:production" },
        "development": { "buildTarget": "fleet:build:development" }
      },
      "defaultConfiguration": "development"
    },
    "test": { "executor": "@nx/vitest:test" },
    "lint": { "executor": "@nx/eslint:lint" }
  }
}
