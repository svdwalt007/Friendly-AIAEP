# Friendly AI AEP Tool - Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================================================
# Deployment Mode
# ============================================================================
# Options: development, staging, production
DEPLOYMENT_MODE=development
NODE_ENV=development

# ============================================================================
# Friendly API Endpoints
# ============================================================================
# Friendly AI Platform API endpoints (3 different environments)

# Primary Friendly API endpoint
FRIENDLY_API_URL_PRIMARY=https://api.friendly.example.com
FRIENDLY_API_KEY_PRIMARY=your-friendly-api-key-primary

# Secondary Friendly API endpoint (staging/testing)
FRIENDLY_API_URL_SECONDARY=https://api-staging.friendly.example.com
FRIENDLY_API_KEY_SECONDARY=your-friendly-api-key-secondary

# Tertiary Friendly API endpoint (backup/development)
FRIENDLY_API_URL_TERTIARY=https://api-dev.friendly.example.com
FRIENDLY_API_KEY_TERTIARY=your-friendly-api-key-tertiary

# ============================================================================
# Anthropic API Configuration
# ============================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_API_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=4096

# ============================================================================
# Application Ports
# ============================================================================
AEP_API_GATEWAY_PORT=3001
AEP_BUILDER_PORT=4200
AEP_PREVIEW_HOST_PORT=3002

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL
DATABASE_URL=postgresql://friendly:friendly_dev_password@localhost:5432/friendly_aep
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=friendly
POSTGRES_PASSWORD=friendly_dev_password
POSTGRES_DB=friendly_aep

# ============================================================================
# Time-Series Database (InfluxDB)
# ============================================================================
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=friendly-dev-token-12345
INFLUXDB_ORG=friendly
INFLUXDB_BUCKET=iot_data
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=friendly_influx_dev

# ============================================================================
# Grafana Configuration
# ============================================================================
GRAFANA_URL=http://localhost:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=friendly_grafana_dev
GRAFANA_API_KEY=

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379

# ============================================================================
# Object Storage (MinIO / S3-compatible)
# ============================================================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=friendly
MINIO_SECRET_KEY=friendly_minio_dev
MINIO_USE_SSL=false
MINIO_BUCKET=friendly-aep-storage

# Alternative S3 configuration (if using AWS S3 instead of MinIO)
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ============================================================================
# Authentication & Security
# ============================================================================
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=24h
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production
REFRESH_TOKEN_EXPIRATION=7d

# Session configuration
SESSION_SECRET=your-session-secret-change-in-production
SESSION_MAX_AGE=86400000

# CORS configuration
CORS_ORIGIN=http://localhost:4200
CORS_CREDENTIALS=true

# ============================================================================
# IoT Configuration
# ============================================================================
# Mock API Server for IoT testing
IOT_MOCK_API_ENABLED=true
IOT_MOCK_API_PORT=3003

# Telegraf configuration
TELEGRAF_ENABLED=true
TELEGRAF_METRICS_PORT=8125
TELEGRAF_HTTP_PORT=8094

# ============================================================================
# Builder Configuration
# ============================================================================
# Git service for project publishing
GIT_PROVIDER=github
GIT_TOKEN=
GIT_DEFAULT_ORG=

# Template marketplace
TEMPLATE_MARKETPLACE_ENABLED=true
TEMPLATE_MARKETPLACE_URL=

# ============================================================================
# Licensing & Billing
# ============================================================================
LICENSE_SERVICE_ENABLED=false
LICENSE_API_URL=
LICENSE_API_KEY=

BILLING_SERVICE_ENABLED=false
BILLING_PROVIDER=stripe
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================================================
# Audit & Logging
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json
AUDIT_ENABLED=true
AUDIT_LOG_PATH=./logs/audit.log

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_IOT_ENABLED=true
FEATURE_BUILDER_ENABLED=true
FEATURE_GRAFANA_INTEGRATION=true
FEATURE_AI_AGENT_RUNTIME=true

# ============================================================================
# Development Tools
# ============================================================================
# Enable development features
DEV_MODE=true
DEV_DEBUG_ENABLED=true
DEV_MOCK_SERVICES=true

# Hot reload
WATCH_MODE=true

# ============================================================================
# Docker Compose Override
# ============================================================================
COMPOSE_PROJECT_NAME=friendly-aep
COMPOSE_FILE=docker/docker-compose.dev.yml
