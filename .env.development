# ============================================================================
# Friendly AI AEP Tool - Development Environment
# ============================================================================
# This file contains development-specific configuration
# Used for local development with hot-reload and debugging
# ============================================================================

# Deployment Mode
DEPLOYMENT_MODE=development
NODE_ENV=development

# ============================================================================
# Friendly API Endpoints
# ============================================================================
# Development endpoints point to local or dev instances
FRIENDLY_API_URL_PRIMARY=https://api-dev.friendly.example.com
FRIENDLY_API_KEY_PRIMARY=dev_primary_api_key_change_me

FRIENDLY_API_URL_SECONDARY=https://api-dev.friendly.example.com
FRIENDLY_API_KEY_SECONDARY=dev_secondary_api_key_change_me

FRIENDLY_API_URL_TERTIARY=https://api-dev.friendly.example.com
FRIENDLY_API_KEY_TERTIARY=dev_tertiary_api_key_change_me

# ============================================================================
# Anthropic API Configuration
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME_your_anthropic_key
ANTHROPIC_API_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=4096

# ============================================================================
# Application Ports
# ============================================================================
AEP_API_GATEWAY_PORT=3001
AEP_BUILDER_PORT=4200
AEP_PREVIEW_HOST_PORT=3002

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL - Development database
DATABASE_URL=postgresql://friendly:friendly_dev_password@localhost:46100/friendly_aep_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=friendly
POSTGRES_PASSWORD=friendly_dev_password
POSTGRES_DB=friendly_aep_dev

# ============================================================================
# Time-Series Database (InfluxDB)
# ============================================================================
INFLUXDB_URL=http://localhost:46101
INFLUXDB_TOKEN=friendly-dev-token-12345
INFLUXDB_ORG=friendly
INFLUXDB_BUCKET=iot_data
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=friendly_influx_dev

# ============================================================================
# Grafana Configuration
# ============================================================================
GRAFANA_URL=http://localhost:45001
GRAFANA_ROOT_URL=http://localhost:45001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=friendly_grafana_dev
GRAFANA_API_KEY=

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:46102

# ============================================================================
# Object Storage (MinIO)
# ============================================================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=friendly
MINIO_SECRET_KEY=friendly_minio_dev
MINIO_USE_SSL=false
MINIO_BUCKET=friendly-aep-storage

# ============================================================================
# Authentication & Security
# ============================================================================
# Use weak secrets for development only
JWT_SECRET=dev_jwt_secret_minimum_32_characters_long_here
JWT_EXPIRATION=24h
REFRESH_TOKEN_SECRET=dev_refresh_secret_minimum_32_characters_long
REFRESH_TOKEN_EXPIRATION=7d

SESSION_SECRET=dev_session_secret_minimum_32_characters_long
SESSION_MAX_AGE=86400000

# CORS - Allow all origins in development
CORS_ORIGIN=http://localhost:45000
CORS_CREDENTIALS=true

# ============================================================================
# IoT Configuration
# ============================================================================
IOT_MOCK_API_ENABLED=true
IOT_MOCK_API_PORT=3003

TELEGRAF_ENABLED=true
TELEGRAF_METRICS_PORT=8125
TELEGRAF_HTTP_PORT=8094

# ============================================================================
# Builder Configuration
# ============================================================================
GIT_PROVIDER=github
GIT_TOKEN=
GIT_DEFAULT_ORG=

TEMPLATE_MARKETPLACE_ENABLED=true
TEMPLATE_MARKETPLACE_URL=

# ============================================================================
# Licensing & Billing
# ============================================================================
# Disabled in development
LICENSE_SERVICE_ENABLED=false
LICENSE_API_URL=
LICENSE_API_KEY=

BILLING_SERVICE_ENABLED=false
BILLING_PROVIDER=stripe
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================================================
# Audit & Logging
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=pretty
AUDIT_ENABLED=true
AUDIT_LOG_PATH=./logs/audit.log

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_IOT_ENABLED=true
FEATURE_BUILDER_ENABLED=true
FEATURE_GRAFANA_INTEGRATION=true
FEATURE_AI_AGENT_RUNTIME=true

# ============================================================================
# Development Tools
# ============================================================================
DEV_MODE=true
DEV_DEBUG_ENABLED=true
DEV_MOCK_SERVICES=true
WATCH_MODE=true

# ============================================================================
# Docker Compose
# ============================================================================
COMPOSE_PROJECT_NAME=friendly-aep-dev
COMPOSE_FILE=docker/docker-compose.dev.yml
